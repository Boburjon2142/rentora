DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,yourusername.pythonanywhere.com
DJANGO_TIME_ZONE=UTC
DJANGO_SECURE_SSL_REDIRECT=False
PYTHONANYWHERE_DOMAIN=yourusername.pythonanywhere.com
DATABASE_URL=sqlite:///db.sqlite3
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourusername.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://yourusername.pythonanywhere.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
